# Prod ortamı — compose: definitions.env + bu dosya
# Bash: source lib/load-definitions.sh prod

# Uygulama reposu (main/master / ayrı remote mümkün)
APP_GIT_BRANCH=master

API_ENDPOINT=https://portal.seleniumorchestrator.com

ELASTIC_ENDPOINT=https://elk-es01-1:9200/
FRONTEND_HEALTHCHECK_URL=http://seleniumorchestrator-prod-Frontend-1:80/myenv.js

# docker-compose.base.yml parametreleri
DEPLOY_ENV=prod
ASPNETCORE_ENV=Prod

# SmsService (docker-compose.base.yml) — ASP.NET env ile aynı dosyadan
SMS_SERVICE_ISTEST=false
MAILPIT_HOST=rinten-mailpit
MAILPIT_PORT=1025
MAILPIT_ACTIVE=true

# SmsService Netgsm (compose; appsettings.Prod ile uyumlu)
NETGSM_ENDPOINT=https://api.netgsm.com.tr/
NETGSM_USERCODE=3129110112
NETGSM_MESSAGE_HEADER=RINTENSOFT
NETGSM_APP_KEY=xxx
NETGSM_PASSWORD=1-A9B16
NETGSM_IYS_CODE=644535

KEYCLOAK_REALM=seleniumorchestrator_prod

# -- PRESERVE BEGIN: EkContainerlarIcinEnvDegerleri -- #
# -- PRESERVE END: EkContainerlarIcinEnvDegerleri -- #

# Yedek / Postgres (prod stack)
BACKUP_PROD_DIR=${DEVOPS_HOME}/backup/${PROJECT_TITLE}/prod
# docker-compose.base.yml container_name ile aynı; harici Postgres: or. db-postgres-prod-1
POSTGRES_BACKUP_CONTAINER_PROD=${PROJECT_TITLE}-prod-postgresql-1

# -- PRESERVE BEGIN: TurnstileSettings -- #
TURNSTILE_ENABLED=true
TURNSTILE_SITE_KEY=0xXXXXXXXXXXXXXXXXXXXXXX
TURNSTILE_SECRET_KEY=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# -- PRESERVE END: TurnstileSettings -- #