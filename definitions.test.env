# Test ortamı — compose: definitions.env + bu dosya
# Bash: source lib/load-definitions.sh test

# Uygulama reposu (test dalı / ayrı remote mümkün)
APP_GIT_BRANCH=test

API_ENDPOINT=https://portaltest.seleniumorchestrator.com

ELASTIC_ENDPOINT=
FRONTEND_HEALTHCHECK_URL=

# docker-compose.base.yml parametreleri
DEPLOY_ENV=test
ASPNETCORE_ENV=Test

# SmsService (docker-compose.base.yml) — ASP.NET env ile aynı dosyadan
SMS_SERVICE_ISTEST=true
MAILPIT_HOST=rinten-mailpit
MAILPIT_PORT=1025
MAILPIT_ACTIVE=true

KEYCLOAK_REALM=seleniumorchestrator_test

# -- PRESERVE BEGIN: EkContainerlarIcinEnvDegerleri -- #
# -- PRESERVE END: EkContainerlarIcinEnvDegerleri -- #

# Yedek / Postgres (test stack)
BACKUP_TEST_DIR=${DEVOPS_HOME}/backup/${PROJECT_TITLE}/test
# docker-compose.base.yml container_name ile aynı; harici Postgres: or. db-postgres-prod-1
POSTGRES_BACKUP_CONTAINER_TEST=${PROJECT_TITLE}-test-postgresql-1

# -- PRESERVE BEGIN: TurnstileSettings -- #
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=-
TURNSTILE_SECRET_KEY=-
# -- PRESERVE END: TurnstileSettings -- #