# SeleniumOrchestratorStack ortak tanımlar.
# Bash:  source lib/load-definitions.sh [test|prod]
# Compose: lib/compose.sh üzerinden çağrılır — PROJECT_TITLE ve DEVOPS_HOME
#          tüm path'lerin tek kaynağıdır.
#
# Yeni proje için: sadece PROJECT_TITLE değiştir.

DEVOPS_HOME=/home/devops
PROJECT_TITLE=seleniumorchestrator
# Kalıcı Docker volume’ların host kökü (compose’ta ${VOLUME_ROOT}/... olarak kullanılır).
# Eski docker compose iç içe ${} çözmezse tek satır yazın: VOLUME_ROOT=/home/devops/volumes/seleniumorchestrator
VOLUME_ROOT=${DEVOPS_HOME}/volumes/${PROJECT_TITLE}
NETWORK_NAME=seleniumorchestratorNetwork

# Kaynak ağaçları (test/prod ortak; PROJECT_TITLE ile türetilir)
APP_SOURCE_DIR=${DEVOPS_HOME}/source/${PROJECT_TITLE}
STACK_SOURCE_DIR=${DEVOPS_HOME}/source/${PROJECT_TITLE}stack

# Compose'dan bağımsız, proje adına göre türetilemeyen yollar
GENELSERVISLER_SOURCE_DIR=/home/devops/source/genelservisler

GIT_REMOTE_STACK=https://gitlab.com/rintensoft/seleniumorchestratorstack.git
GIT_REMOTE_GENELSERVISLER=https://gitlab.com/rintensoft/genelservisler.git
GIT_REMOTE_APP=https://gitlab.com/rintensoft/SeleniumOrchestrator.git
GITLAB_BASE_URL=https://gitlab.com/rintensoft

NUGET_HOST=nuget.rintensoft.com

